# KubeOps Agent — Environment Variables

# Ollama Configuration (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Google Gemini Configuration (Cloud LLM) 
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=models/gemini-2.0-flash
GEMINI_EMBED_MODEL=models/text-embedding-004

# Anthropic Configuration (Cloud LLM)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Default LLM Provider: "ollama", "gemini" or "anthropic"
DEFAULT_PROVIDER=ollama

# ChromaDB Persistent Storage
CHROMA_PERSIST_DIR=./data/chromadb

# Upload Directory
UPLOAD_DIR=./data/uploads

# Max File Size (MB)
MAX_FILE_SIZE_MB=10

# Kubeconfig Path (leave default for standard location)
KUBECONFIG_PATH=~/.kube/config
